# URL del API del chatbot (flowai-gemini-server-js). Copia este archivo a .env y ajusta.
#
# Local (testear): backend corriendo en tu máquina
#   NEXT_PUBLIC_CHAT_API_URL=http://localhost:3000
#
# Producción (landing en https://flowai.cl): URL pública donde esté desplegado el backend del chat
#   ej. NEXT_PUBLIC_CHAT_API_URL=https://api.flowai.cl
#   (no uses https://flowai.cl aquí: esa es la landing; el API es otro servicio)
NEXT_PUBLIC_CHAT_API_URL=http://localhost:3000
